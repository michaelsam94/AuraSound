<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- AuraSound background: deep indigo -> violet diagonal gradient -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#FF1A1A2E" />
                <item android:offset="0.55" android:color="#FF2A1B4E" />
                <item android:offset="1.0" android:color="#FF3D2A6B" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft radial aura glow behind the foreground -->
    <path android:pathData="M54,54 m-46,0 a46,46 0 1,0 92,0 a46,46 0 1,0 -92,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="46">
                <item android:offset="0.0" android:color="#403FA0FF" />
                <item android:offset="0.6" android:color="#1A6C5CE0" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>
</vector>

<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- AuraSound foreground: a glowing core with concentric sound ripples.
         All content stays inside the 66dp adaptive-icon safe zone. -->

    <!-- Outer ripple -->
    <path
        android:pathData="M54,54 m-31,0 a31,31 0 1,0 62,0 a31,31 0 1,0 -62,0"
        android:strokeWidth="3"
        android:strokeColor="#40FFFFFF"
        android:fillColor="#00000000" />

    <!-- Middle ripple -->
    <path
        android:pathData="M54,54 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0"
        android:strokeWidth="3.5"
        android:strokeColor="#80B8C8FF"
        android:fillColor="#00000000" />

    <!-- Inner ripple -->
    <path
        android:pathData="M54,54 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"
        android:strokeWidth="4"
        android:strokeColor="#FFDCE4FF"
        android:fillColor="#00000000" />

    <!-- Glowing core -->
    <path android:pathData="M54,54 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="7">
                <item android:offset="0.0" android:color="#FFFFFFFF" />
                <item android:offset="1.0" android:color="#FF7FB0FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
